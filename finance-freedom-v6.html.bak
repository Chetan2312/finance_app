    <div class="card"><div class="sh"><div class="shdot" style="background:var(--amber)"></div>Step-by-Step Plan</div><div id="inv-steps"><div class="empty xxs">Generating your plan...</div></div></div>
    <div class="card"><div class="sh"><div class="shdot" style="background:var(--lime)"></div>Asset Allocation</div><canvas id="alloc-c" style="max-height:170px"></canvas><div id="alloc-leg" class="flex wrap gap4 mt1"></div></div>
  </div>
