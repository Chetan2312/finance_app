<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>FinanceFreedom v6</title>
<link href="https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@400;500;700;800;900&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
/* ═══════════════════════════════
   DESIGN TOKENS
═══════════════════════════════ */
:root{
  /* Surfaces */
  --bg:#05050f;
  --bg2:#0b0b1a;
  --s0:#101022;
  --s1:#161630;
  --s2:#1c1c3a;
  --s3:#232342;

  /* Borders */
  --b1:#252545;
  --b2:#30305a;
  --b3:#3d3d70;

  /* Brand palette */
  --p:#7c73e6;      /* primary indigo */
  --p2:#a598ff;     /* primary light */
  --pg:linear-gradient(135deg,#6c63d5,#9b8ff0);

  --rose:#fb7185;   /* accent rose */
  --teal:#2dd4bf;   /* teal */
  --amber:#f59e0b;  /* amber */
  --lime:#86efac;   /* lime */
  --sky:#38bdf8;    /* sky */
  --coral:#fb923c;  /* coral */

  /* Semantic */
  --ok:#10b981;
  --ok-s:rgba(16,185,129,.12);
  --warn:#f59e0b;
  --warn-s:rgba(245,158,11,.12);
  --danger:#f43f5e;
  --danger-s:rgba(244,63,94,.12);
  --info-s:rgba(124,115,230,.12);

  /* Text */
  --t1:#f1f5f9;
  --t2:#94a3b8;
  --t3:#475569;

  /* Type */
  --fd:'Cabinet Grotesk',sans-serif;
  --fb:'Outfit',sans-serif;
  --fm:'JetBrains Mono',monospace;

  /* Spacing & shape */
  --r:14px;
  --rm:9px;
  --rs:6px;
  --sh:0 8px 40px rgba(0,0,0,.6);
  --sh2:0 2px 12px rgba(0,0,0,.35);
  --tr:.16s cubic-bezier(.4,0,.2,1);
}
[data-theme=light]{
  --bg:#f0f1ff;
  --bg2:#e8e9ff;
  --s0:#ffffff;
  --s1:#f5f5ff;
  --s2:#eeefff;
  --s3:#e8e9ff;
  --b1:#dde0ff;
  --b2:#c5c9f5;
  --b3:#abaee8;
  --t1:#0f172a;
  --t2:#475569;
  --t3:#94a3b8;
  --sh:0 4px 24px rgba(100,100,200,.1);
  --sh2:0 2px 8px rgba(100,100,200,.08);
}

/* ═══════════════════════════════
   BASE
═══════════════════════════════ */
*{box-sizing:border-box;margin:0;padding:0}
html{font-size:15px;scroll-behavior:smooth}
body{background:var(--bg);color:var(--t1);font-family:var(--fb);min-height:100vh;overflow-x:hidden;transition:background .3s,color .3s}
::selection{background:rgba(124,115,230,.35);color:var(--t1)}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--b2);border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:var(--b3)}

/* ═══════════════════════════════
   LAYOUT
═══════════════════════════════ */
.wrap{max-width:1220px;margin:0 auto;padding:0 1.2rem 3rem}

/* ═══════════════════════════════
   HEADER
═══════════════════════════════ */
.hdr{position:sticky;top:0;z-index:60;background:var(--bg);border-bottom:1px solid var(--b1);padding:.9rem 1.2rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.8rem;backdrop-filter:blur(20px)}
.logo{display:flex;flex-direction:column;gap:1px}
.logo-mark{font-family:var(--fd);font-size:1.5rem;font-weight:900;letter-spacing:-.04em;background:linear-gradient(135deg,var(--p2) 0%,var(--rose) 50%,var(--amber) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.logo-sub{font-family:var(--fm);font-size:.55rem;color:var(--t3);letter-spacing:.14em}
.hdr-r{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}

/* save badge */
.sav-badge{display:flex;align-items:center;gap:.3rem;font-family:var(--fm);font-size:.57rem;padding:.2rem .6rem;border-radius:20px;background:var(--ok-s);color:var(--ok);border:1px solid rgba(16,185,129,.3);letter-spacing:.06em;transition:all .3s}
.sav-badge.busy{background:var(--warn-s);color:var(--warn);border-color:rgba(245,158,11,.3)}
.sav-dot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0;animation:pdot 2s infinite}
@keyframes pdot{0%,100%{opacity:1}50%{opacity:.2}}

/* icon button */
.ico-btn{width:32px;height:32px;border-radius:50%;border:1px solid var(--b1);background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.85rem;transition:all var(--tr);color:var(--t2)}
.ico-btn:hover{background:var(--info-s);border-color:var(--p);color:var(--p);transform:scale(1.08)}

/* ═══════════════════════════════
   TAB NAV
═══════════════════════════════ */
.nav{background:var(--s0);border-bottom:1px solid var(--b1);padding:0 1.2rem;display:flex;gap:0;overflow-x:auto;-ms-overflow-style:none;scrollbar-width:none}
.nav::-webkit-scrollbar{display:none}
.ntab{padding:.72rem 1rem;font-size:.73rem;font-weight:600;font-family:var(--fb);color:var(--t3);border:none;background:transparent;cursor:pointer;border-bottom:2px solid transparent;transition:all var(--tr);white-space:nowrap;letter-spacing:.01em;display:flex;align-items:center;gap:.35rem}
.ntab:hover{color:var(--t1)}
.ntab.on{color:var(--p2);border-bottom-color:var(--p)}

/* ═══════════════════════════════
   PAGES
═══════════════════════════════ */
.page{display:none;padding-top:1.4rem}
.page.on{display:block;animation:pgIn .25s ease}
@keyframes pgIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* ═══════════════════════════════
   GRID
═══════════════════════════════ */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}
.g3{display:grid;grid-template-columns:repeat(3,1fr);gap:.9rem}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:.8rem}
.s2{grid-column:span 2}.s3{grid-column:span 3}.s4{grid-column:span 4}
.mb1{margin-bottom:.9rem}.mb2{margin-bottom:1.5rem}.mt1{margin-top:.8rem}.mt05{margin-top:.4rem}

/* ═══════════════════════════════
   CARDS
═══════════════════════════════ */
.card{background:var(--s0);border:1px solid var(--b1);border-radius:var(--r);padding:1.15rem;transition:border-color var(--tr)}
.card.glow:hover{border-color:var(--p);box-shadow:0 0 0 1px var(--p),var(--sh2)}

/* KPI card */
.kcard{background:var(--s0);border:1px solid var(--b1);border-radius:var(--r);padding:1rem 1.15rem;transition:all var(--tr);position:relative;overflow:hidden}
.kcard::after{content:'';position:absolute;inset:0;opacity:0;transition:opacity var(--tr);border-radius:var(--r)}
.kcard:hover{transform:translateY(-2px);box-shadow:var(--sh2)}
.kl{font-family:var(--fm);font-size:.57rem;text-transform:uppercase;letter-spacing:.1em;color:var(--t3);margin-bottom:.35rem}
.kv{font-family:var(--fd);font-size:1.6rem;font-weight:900;letter-spacing:-.03em;line-height:1}
.ks{font-size:.68rem;color:var(--t3);margin-top:.28rem}

/* ═══════════════════════════════
   SECTION TITLES
═══════════════════════════════ */
.sh{font-family:var(--fd);font-size:.95rem;font-weight:800;display:flex;align-items:center;gap:.45rem;margin-bottom:.8rem;letter-spacing:-.02em}
.shdot{width:6px;height:20px;border-radius:3px;background:var(--pg);flex-shrink:0}

/* ═══════════════════════════════
   FORM ELEMENTS
═══════════════════════════════ */
.fi{display:flex;flex-direction:column;gap:.25rem;margin-bottom:.7rem}
.fi label{font-family:var(--fm);font-size:.57rem;text-transform:uppercase;letter-spacing:.08em;color:var(--t3)}
.fi input,.fi select,.fi textarea{background:var(--bg2);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.55rem .8rem;color:var(--t1);font-family:var(--fb);font-size:.82rem;outline:none;transition:border-color var(--tr),box-shadow var(--tr);width:100%}
.fi input:focus,.fi select:focus,.fi textarea:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(124,115,230,.18)}
.fi select option{background:var(--s1)}
.fi input[type=date]{color-scheme:dark}
[data-theme=light] .fi input[type=date]{color-scheme:light}
.fi input::placeholder{color:var(--b3)}

/* ═══════════════════════════════
   BUTTONS
═══════════════════════════════ */
.btn{padding:.55rem 1.1rem;border-radius:var(--rm);border:none;font-family:var(--fb);font-weight:600;font-size:.78rem;cursor:pointer;transition:all var(--tr);display:inline-flex;align-items:center;gap:.35rem;white-space:nowrap;letter-spacing:.01em}
.bp{background:var(--pg);color:#fff;box-shadow:0 2px 10px rgba(108,99,213,.3)}.bp:hover{filter:brightness(1.12);transform:translateY(-1px);box-shadow:0 4px 18px rgba(108,99,213,.4)}
.bg{background:var(--s1);color:var(--t1);border:1.5px solid var(--b1)}.bg:hover{border-color:var(--p);color:var(--p);background:var(--info-s)}
.bd{background:var(--danger-s);color:var(--danger);border:1.5px solid rgba(244,63,94,.35)}.bd:hover{background:var(--danger);color:#fff}
.bok{background:var(--ok-s);color:var(--ok);border:1.5px solid rgba(16,185,129,.3)}.bok:hover{background:var(--ok);color:#fff}
.bwarn{background:var(--warn-s);color:var(--warn);border:1.5px solid rgba(245,158,11,.3)}.bwarn:hover{background:var(--warn);color:#fff}
.bsm{padding:.28rem .62rem;font-size:.68rem;border-radius:var(--rs)}
.bxs{padding:.18rem .45rem;font-size:.6rem;border-radius:5px}
.bic{width:28px;height:28px;padding:0;display:inline-flex;align-items:center;justify-content:center;border-radius:var(--rs);flex-shrink:0}

/* ═══════════════════════════════
   BADGES
═══════════════════════════════ */
.bdg{font-size:.57rem;padding:2px 7px;border-radius:20px;font-weight:700;font-family:var(--fm);letter-spacing:.05em}
.bdg-p{background:var(--info-s);color:var(--p2);border:1px solid rgba(124,115,230,.4)}
.bdg-ok{background:var(--ok-s);color:var(--ok);border:1px solid rgba(16,185,129,.3)}
.bdg-dan{background:var(--danger-s);color:var(--danger);border:1px solid rgba(244,63,94,.3)}
.bdg-warn{background:var(--warn-s);color:var(--warn);border:1px solid rgba(245,158,11,.3)}
.bdg-muted{background:var(--s2);color:var(--t3);border:1px solid var(--b1)}
.bdg-sky{background:rgba(56,189,248,.1);color:var(--sky);border:1px solid rgba(56,189,248,.3)}
.bdg-teal{background:rgba(45,212,191,.1);color:var(--teal);border:1px solid rgba(45,212,191,.3)}

/* ═══════════════════════════════
   RINGS
═══════════════════════════════ */
.rw{position:relative;display:flex;align-items:center;justify-content:center}
svg.ring circle{fill:none;stroke-width:8}
.rbg{stroke:var(--b1)}
.rfg{stroke-linecap:round;transition:stroke-dashoffset .8s cubic-bezier(.4,0,.2,1);transform:rotate(-90deg);transform-origin:50% 50%}
.rc{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}

/* ═══════════════════════════════
   PROGRESS BAR
═══════════════════════════════ */
.pb{height:5px;background:var(--b1);border-radius:3px;overflow:hidden}
.pbf{height:100%;border-radius:3px;transition:width .6s cubic-bezier(.4,0,.2,1)}

/* ═══════════════════════════════
   TIMELINE
═══════════════════════════════ */
.tl{padding-left:1.2rem;position:relative}
.tl::before{content:'';position:absolute;left:5px;top:6px;bottom:6px;width:1px;background:linear-gradient(to bottom,var(--p),var(--b1))}
.tli{position:relative;margin-bottom:.8rem}
.tld{position:absolute;left:-1.2rem;top:3px;width:11px;height:11px;border-radius:50%;border:2px solid var(--p);background:var(--bg);transition:all var(--tr)}
.tld.done{background:var(--p);box-shadow:0 0 8px rgba(124,115,230,.5)}
.tld.gold{border-color:var(--amber);background:var(--amber);box-shadow:0 0 8px rgba(245,158,11,.5)}
.tld.teal{border-color:var(--teal);background:var(--teal)}
.tl-t{font-weight:700;font-size:.8rem}
.tl-d{font-size:.67rem;color:var(--t3);margin-top:2px;font-family:var(--fm)}

/* ═══════════════════════════════
   EXPENSE ACCORDION SECTIONS
═══════════════════════════════ */
.esec{background:var(--s0);border:1px solid var(--b1);border-radius:var(--r);margin-bottom:.7rem;overflow:hidden;transition:border-color var(--tr)}
.esec:hover{border-color:var(--b2)}
.esec-hd{display:flex;align-items:center;gap:.5rem;padding:.78rem .95rem;cursor:pointer;user-select:none;transition:background var(--tr)}
.esec-hd:hover{background:var(--s1)}
.esec-nm{font-family:var(--fd);font-size:.85rem;font-weight:800;flex:1;letter-spacing:-.02em}
.esec-tot{font-family:var(--fm);font-size:.8rem;color:var(--t2);margin-right:.4rem}
.esec-arr{font-size:.6rem;color:var(--t3);transition:transform .2s}
.esec-arr.op{transform:rotate(180deg)}
.esec-bd{display:none;padding:.85rem .95rem;border-top:1px solid var(--b1)}
.esec-bd.op{display:block;animation:sld .2s ease}
@keyframes sld{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:none}}
.egrid{display:grid;grid-template-columns:repeat(3,1fr);gap:.42rem;margin-bottom:.55rem}
.ei{background:var(--bg2);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.5rem .68rem;transition:border-color var(--tr);position:relative}
.ei:focus-within{border-color:var(--p);box-shadow:0 0 0 2px rgba(124,115,230,.14)}
.ei:hover .eidel{opacity:1}
.eidel{position:absolute;top:3px;right:3px;opacity:0;transition:opacity var(--tr);width:15px;height:15px;border-radius:4px;background:var(--danger-s);border:none;color:var(--danger);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.52rem;padding:0;line-height:1}
.eilb{font-size:.58rem;color:var(--t3);font-family:var(--fm);margin-bottom:.22rem;padding-right:16px}
.eirow{display:flex;align-items:center;gap:3px}
.rp{color:var(--t3);font-size:.7rem;font-family:var(--fm)}
.einp{width:100%;background:transparent;border:none;color:var(--t1);font-family:var(--fm);font-size:.88rem;font-weight:500;outline:none}
.einp::placeholder{color:var(--b2)}
.sub-list{display:flex;flex-direction:column;gap:.38rem}
.sub-row{display:flex;align-items:center;gap:.5rem;background:var(--bg2);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.48rem .7rem;transition:border-color var(--tr)}
.sub-row:hover{border-color:var(--b2)}
.sub-n{flex:1;font-size:.78rem;font-weight:600;display:flex;align-items:center;gap:.38rem;flex-wrap:wrap}
.sub-m{font-size:.62rem;color:var(--t3);font-family:var(--fm);margin-top:2px}
.sub-a{font-family:var(--fm);font-size:.82rem;color:var(--rose);min-width:62px;text-align:right;font-weight:500}
.lbdg{font-size:.52rem;padding:1px 5px;border-radius:4px;background:var(--info-s);color:var(--p2);border:1px solid rgba(124,115,230,.4);font-family:var(--fm)}
.addrow{display:flex;gap:.38rem;flex-wrap:wrap;margin-top:.48rem;align-items:center}
.ainp{flex:1;min-width:100px;background:var(--bg2);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.38rem .62rem;color:var(--t1);font-family:var(--fm);font-size:.73rem;outline:none;transition:border-color var(--tr)}
.ainp:focus{border-color:var(--p)}

/* ═══════════════════════════════
   DEBT / SIP CARDS
═══════════════════════════════ */
.dcard{background:var(--s0);border:1.5px solid var(--b1);border-radius:var(--r);padding:1rem;margin-bottom:.65rem;transition:all var(--tr);position:relative;overflow:hidden}
.dcard:hover{border-color:var(--b2);transform:translateY(-1px);box-shadow:var(--sh2)}
.dcard-stripe{position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:2px 0 0 2px}
.dcard-hd{display:flex;align-items:center;gap:.65rem;margin-bottom:.65rem}
.dcard-ico{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0}
.dcard-ti{flex:1;min-width:0}
.dcard-nm{font-weight:800;font-size:.85rem;display:flex;align-items:center;gap:.38rem;flex-wrap:wrap;font-family:var(--fd);letter-spacing:-.01em}
.dcard-mt{font-size:.62rem;color:var(--t3);font-family:var(--fm);margin-top:2px}
.dcard-rt{text-align:right;flex-shrink:0}
.dcard-amt{font-family:var(--fd);font-size:1rem;font-weight:900;letter-spacing:-.02em}
.dcard-acts{display:flex;gap:.32rem;justify-content:flex-end;margin-top:.55rem}
.sipcard{background:var(--s0);border:1.5px solid var(--b1);border-radius:var(--r);padding:1rem;margin-bottom:.65rem;transition:all var(--tr);position:relative}
.sipcard:hover{border-color:var(--b2);transform:translateY(-1px);box-shadow:var(--sh2)}
.sip-sts{display:grid;grid-template-columns:repeat(4,1fr);gap:.38rem}
.sip-st{background:var(--bg2);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.42rem .52rem;text-align:center}
.sip-stl{font-size:.52rem;color:var(--t3);font-family:var(--fm);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px}
.sip-stv{font-family:var(--fd);font-size:.85rem;font-weight:800}
.sip-proj-bar{height:7px;border-radius:4px;background:var(--b1);margin:.3rem 0;overflow:hidden;display:flex}
.spi{height:100%;background:var(--p);border-radius:4px 0 0 4px}
.spg{height:100%;background:var(--lime)}
.rdots{display:flex;gap:3px}
.rdot{width:8px;height:4px;border-radius:2px;background:var(--b1);transition:background var(--tr)}
.rdot.on{background:var(--p)}.rdot.on.m{background:var(--amber)}.rdot.on.h{background:var(--danger)}

/* ═══════════════════════════════
   DAILY EXPENSES
═══════════════════════════════ */
.dex-quick{background:var(--s0);border:1.5px solid var(--b1);border-radius:var(--r);padding:1.1rem;margin-bottom:.9rem}
.dex-row{display:flex;gap:.5rem;align-items:flex-end;flex-wrap:wrap}
.dex-row .fi{flex:1;min-width:110px;margin-bottom:0}
.dex-entry{display:flex;align-items:center;gap:.6rem;background:var(--bg2);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.55rem .75rem;margin-bottom:.42rem;transition:all var(--tr)}
.dex-entry:hover{border-color:var(--b2)}
.dex-date{font-family:var(--fm);font-size:.65rem;color:var(--t3);min-width:72px}
.dex-cat-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.dex-label{flex:1;font-size:.8rem;font-weight:600;display:flex;align-items:center;gap:.4rem}
.dex-note{font-size:.65rem;color:var(--t3);font-style:italic}
.dex-amt{font-family:var(--fm);font-size:.85rem;font-weight:600;color:var(--rose);min-width:60px;text-align:right}
.dex-acts{display:flex;gap:.25rem}
.dex-day-hd{display:flex;align-items:center;gap:.5rem;padding:.55rem 0;border-bottom:1.5px solid var(--b1);margin-bottom:.4rem}
.dex-day-lbl{font-family:var(--fd);font-weight:800;font-size:.82rem}
.dex-day-tot{margin-left:auto;font-family:var(--fm);font-size:.72rem;color:var(--rose)}
.cat-pill{display:inline-flex;align-items:center;gap:.28rem;padding:.22rem .55rem;border-radius:20px;font-size:.65rem;font-weight:600;cursor:pointer;transition:all var(--tr);border:1.5px solid var(--b1)}
.cat-pill:hover{transform:scale(1.04)}
.cat-mgr{display:flex;flex-wrap:wrap;gap:.38rem;margin-bottom:.7rem}

/* ═══════════════════════════════
   REPORT SECTION
═══════════════════════════════ */
.report-controls{background:var(--s0);border:1.5px solid var(--b1);border-radius:var(--r);padding:1.15rem;margin-bottom:.9rem}
.report-preview{background:var(--s0);border:1.5px solid var(--b1);border-radius:var(--r);padding:1.5rem;margin-bottom:.9rem}
.rpt-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:2px solid var(--b1)}
.rpt-title{font-family:var(--fd);font-size:1.4rem;font-weight:900;background:linear-gradient(135deg,var(--p2),var(--rose));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.rpt-period{font-family:var(--fm);font-size:.65rem;color:var(--t3);margin-top:3px}
.rpt-kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:.7rem;margin-bottom:1.4rem}
.rpt-kpi{background:var(--s1);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.8rem;text-align:center}
.rpt-kpi-l{font-family:var(--fm);font-size:.57rem;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);margin-bottom:.3rem}
.rpt-kpi-v{font-family:var(--fd);font-size:1.2rem;font-weight:900;letter-spacing:-.02em}

/* Gantt chart */
.gantt-wrap{overflow-x:auto;margin-bottom:1.4rem}
.gantt{min-width:600px}
.gantt-hd-row{display:flex;margin-bottom:2px}
.gantt-label-col{width:130px;flex-shrink:0}
.gantt-dates{flex:1;display:flex}
.gantt-date-cell{flex:1;text-align:center;font-family:var(--fm);font-size:.5rem;color:var(--t3);padding-bottom:3px;border-left:1px solid var(--b1)}
.gantt-row{display:flex;align-items:center;margin-bottom:3px}
.gantt-cat{width:130px;flex-shrink:0;font-size:.72rem;font-weight:600;padding-right:.6rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;display:flex;align-items:center;gap:.35rem}
.gantt-cells{flex:1;display:flex;height:22px;border-radius:3px;overflow:hidden}
.gantt-cell{flex:1;position:relative;border-left:1px solid var(--bg)}
.gantt-cell-fill{position:absolute;inset:1px;border-radius:2px;transition:opacity var(--tr)}
.gantt-cell:hover .gantt-cell-fill{filter:brightness(1.3)}
.gantt-legend{display:flex;align-items:center;gap:.5rem;font-size:.62rem;color:var(--t3);margin-top:.5rem;font-family:var(--fm)}
.gantt-scale{display:flex;align-items:center;gap:4px}
.gantt-scale span{width:12px;height:8px;border-radius:2px;display:inline-block}

/* Report table */
.rpt-table{width:100%;border-collapse:collapse;font-size:.75rem}
.rpt-table th{font-family:var(--fm);font-size:.58rem;text-transform:uppercase;letter-spacing:.08em;color:var(--t3);padding:.5rem .7rem;border-bottom:1.5px solid var(--b1);text-align:left}
.rpt-table td{padding:.5rem .7rem;border-bottom:1px solid var(--b1)}
.rpt-table tr:last-child td{border-bottom:none}
.rpt-table tr:hover td{background:var(--s1)}

/* ═══════════════════════════════
   MODALS
═══════════════════════════════ */
.ovl{display:none;position:fixed;inset:0;background:rgba(0,0,0,.78);z-index:300;align-items:center;justify-content:center;padding:1rem;backdrop-filter:blur(8px)}
.ovl.on{display:flex;animation:ovFd .18s ease}
@keyframes ovFd{from{opacity:0}to{opacity:1}}
.modal{background:var(--s0);border:1.5px solid var(--b2);border-radius:var(--r);padding:1.35rem;width:440px;max-width:100%;max-height:92vh;overflow-y:auto;box-shadow:var(--sh);animation:moSl .22s cubic-bezier(.4,0,.2,1)}
@keyframes moSl{from{opacity:0;transform:scale(.95) translateY(12px)}to{opacity:1;transform:none}}
.mo-t{font-family:var(--fd);font-size:1rem;font-weight:900;margin-bottom:.9rem;letter-spacing:-.02em}
.mo-ft{display:flex;gap:.42rem;margin-top:.85rem}
.eg{display:grid;grid-template-columns:repeat(8,1fr);gap:.25rem;margin-bottom:.65rem}
.eo{font-size:1rem;padding:.25rem;border-radius:var(--rs);cursor:pointer;text-align:center;border:1.5px solid transparent;transition:all var(--tr)}
.eo:hover,.eo.on{border-color:var(--p);background:var(--info-s)}

/* ═══════════════════════════════
   STRATEGY CARDS
═══════════════════════════════ */
.strat-c{background:var(--s1);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.82rem;margin-bottom:.45rem;cursor:pointer;transition:all var(--tr)}
.strat-c.on,.strat-c:hover{border-color:var(--p);background:var(--info-s)}
.strat-nm{font-weight:700;font-size:.8rem;margin-bottom:.22rem;display:flex;justify-content:space-between;align-items:center}
.strat-d{font-size:.68rem;color:var(--t3);line-height:1.5}

/* ═══════════════════════════════
   UPLOAD ZONE
═══════════════════════════════ */
.upz{border:2px dashed var(--b2);border-radius:var(--r);padding:1.8rem;text-align:center;cursor:pointer;transition:all var(--tr);background:var(--s1)}
.upz:hover,.upz.dg{border-color:var(--p);background:var(--info-s)}
.upz input{display:none}

/* ═══════════════════════════════
   INFO / CALLOUT BOXES
═══════════════════════════════ */
.ib{background:var(--s1);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.72rem;font-size:.72rem;line-height:1.7;color:var(--t3)}
.ib strong{color:var(--t1)}
.cb-ok{background:var(--ok-s);border:1.5px solid rgba(16,185,129,.3);border-radius:var(--rm);padding:.72rem;font-size:.72rem;line-height:1.6;color:var(--ok)}
.cb-dan{background:var(--danger-s);border:1.5px solid rgba(244,63,94,.3);border-radius:var(--rm);padding:.72rem;font-size:.72rem;line-height:1.6;color:var(--danger)}
.cb-warn{background:var(--warn-s);border:1.5px solid rgba(245,158,11,.3);border-radius:var(--rm);padding:.72rem;font-size:.72rem;line-height:1.6;color:var(--warn)}
.cb-info{background:var(--info-s);border:1.5px solid rgba(124,115,230,.3);border-radius:var(--rm);padding:.72rem;font-size:.72rem;line-height:1.6;color:var(--p2)}
.cb-sky{background:rgba(56,189,248,.08);border:1.5px solid rgba(56,189,248,.3);border-radius:var(--rm);padding:.72rem;font-size:.72rem;line-height:1.6;color:var(--sky)}

/* ═══════════════════════════════
   TICKER
═══════════════════════════════ */
.ticker{background:var(--s0);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.38rem .8rem;margin-bottom:.8rem;overflow:hidden}
.ticker-in{display:flex;gap:2.5rem;animation:tk 35s linear infinite;width:max-content}
.ticker-in:hover{animation-play-state:paused}
.ti{display:flex;align-items:center;gap:.38rem;white-space:nowrap}
.ti-n{font-size:.62rem;color:var(--t3);font-family:var(--fm)}
.ti-v{font-size:.68rem;font-family:var(--fm);font-weight:500}
.ti-c{font-size:.6rem;font-family:var(--fm)}
@keyframes tk{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ═══════════════════════════════
   CHAT
═══════════════════════════════ */
.chat-msgs{background:var(--bg2);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.8rem;height:240px;overflow-y:auto;margin-bottom:.65rem;display:flex;flex-direction:column;gap:.52rem}
.msg{max-width:88%;padding:.52rem .82rem;border-radius:var(--rm);font-size:.77rem;line-height:1.55}
.msg.u{align-self:flex-end;background:var(--pg);color:#fff;border-bottom-right-radius:3px}
.msg.a{align-self:flex-start;background:var(--s1);border:1.5px solid var(--b1);border-bottom-left-radius:3px}
.aitg{font-size:.55rem;color:var(--p2);font-family:var(--fm);display:block;margin-bottom:3px;letter-spacing:.06em}
.typing{display:flex;gap:3px;padding:.2rem 0}
.typing span{width:5px;height:5px;background:var(--t3);border-radius:50%;display:inline-block;animation:bd 1.2s infinite}
.typing span:nth-child(2){animation-delay:.2s}.typing span:nth-child(3){animation-delay:.4s}
@keyframes bd{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-5px)}}
.ci{flex:1;background:var(--bg2);border:1.5px solid var(--b1);border-radius:var(--rm);padding:.52rem .8rem;color:var(--t1);font-family:var(--fb);font-size:.77rem;outline:none;transition:border-color var(--tr)}
.ci:focus{border-color:var(--p);box-shadow:0 0 0 2px rgba(124,115,230,.15)}
.chips{display:flex;flex-wrap:wrap;gap:.3rem;margin-bottom:.65rem}
.chip{padding:.22rem .6rem;border-radius:20px;font-size:.67rem;background:var(--s1);border:1.5px solid var(--b1);cursor:pointer;transition:all var(--tr);color:var(--t3)}
.chip:hover{border-color:var(--p);color:var(--p2);background:var(--info-s)}

/* ═══════════════════════════════
   MILESTONE CARDS
═══════════════════════════════ */
.mscard{background:var(--s0);border:1.5px solid var(--b1);border-radius:var(--r);padding:1rem;margin-bottom:.65rem;position:relative;overflow:hidden;transition:all var(--tr)}
.mscard:hover{border-color:var(--b2);transform:translateY(-1px);box-shadow:var(--sh2)}
.ms-stripe{position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:2px 0 0 2px}
.ms-num{position:absolute;top:.7rem;right:.9rem;font-family:var(--fd);font-size:2rem;font-weight:900;color:var(--b1)}
.ms-t{font-family:var(--fd);font-size:.92rem;font-weight:800;margin-bottom:.28rem;letter-spacing:-.02em}
.ms-d{font-size:.72rem;color:var(--t2);line-height:1.65;margin-bottom:.45rem}
.ms-tags{display:flex;gap:.38rem;flex-wrap:wrap}

/* ═══════════════════════════════
   FUND / STEP CARDS
═══════════════════════════════ */
.fund-c{background:var(--s1);border:1.5px solid var(--b1);border-radius:var(--r);padding:.88rem;margin-bottom:.55rem;transition:all var(--tr)}
.fund-c:hover{border-color:var(--b2);transform:translateY(-1px)}
.fund-sts{display:grid;grid-template-columns:repeat(4,1fr);gap:.35rem}
.fund-st{background:var(--bg);border:1.5px solid var(--b1);border-radius:var(--rs);padding:.35rem .45rem;text-align:center}
.fund-stl{font-size:.5rem;color:var(--t3);font-family:var(--fm);text-transform:uppercase;letter-spacing:.04em}
.fund-stv{font-family:var(--fd);font-size:.8rem;font-weight:800;margin-top:1px}
.step-c{display:flex;gap:.7rem;padding:.88rem;background:var(--s1);border:1.5px solid var(--b1);border-radius:var(--r);margin-bottom:.55rem;transition:all var(--tr)}
.step-c:hover{border-color:var(--b2)}
.step-n{width:28px;height:28px;border-radius:50%;background:var(--info-s);border:1.5px solid var(--p);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:900;font-size:.8rem;color:var(--p2);flex-shrink:0;margin-top:1px}

/* ═══════════════════════════════
   UTILITY
═══════════════════════════════ */
.flex{display:flex}.gap4{gap:.4rem}.gap6{gap:.6rem}.gap1{gap:.9rem}
.ac{align-items:center}.jb{justify-content:space-between}.jc{justify-content:center}.wrap{flex-wrap:wrap}
.fw7{font-weight:700}.fw9{font-weight:900}
.mono{font-family:var(--fm)}
.c-p{color:var(--p2)}.c-ok{color:var(--ok)}.c-dan{color:var(--danger)}.c-warn{color:var(--amber)}.c-sky{color:var(--sky)}.c-teal{color:var(--teal)}.c-rose{color:var(--rose)}.c-muted{color:var(--t3)}.c-t2{color:var(--t2)}
.xs{font-size:.65rem}.xxs{font-size:.58rem}
.div{height:1px;background:var(--b1);margin:.7rem 0}
.empty{text-align:center;padding:2rem;color:var(--t3);font-size:.8rem}
.empty-ic{font-size:1.8rem;display:block;margin-bottom:.4rem}

/* PRINT / PDF styles */
@media print{
  .hdr,.nav,.report-controls,.no-print{display:none!important}
  body{background:#fff;color:#000}
  .report-preview{border:none;padding:0}
  .rpt-table td,.rpt-table th{border-color:#ddd}
}

/* RESPONSIVE */
@media(max-width:720px){
  .g2,.g3,.g4{grid-template-columns:1fr}.s2,.s3,.s4{grid-column:span 1}
  .egrid{grid-template-columns:1fr 1fr}
  .sip-sts{grid-template-columns:1fr 1fr}
  .rpt-kpis{grid-template-columns:1fr 1fr}
}
</style>
</head>
<body data-theme="dark">

<!-- ── MODALS ─────────────────────── -->
<div class="ovl" id="mo-sec"><div class="modal">
  <div class="mo-t" id="mo-sec-t">➕ New Expense Section</div>
  <div class="eg" id="eg-sec"></div>
  <div class="fi"><label>Name</label><input id="cs-nm" placeholder="e.g. Business Expenses"></div>
  <div class="fi"><label>Color</label><select id="cs-col"><option value="#7c73e6">Indigo</option><option value="#fb7185">Rose</option><option value="#2dd4bf">Teal</option><option value="#f59e0b">Amber</option><option value="#38bdf8">Sky</option><option value="#fb923c">Coral</option><option value="#a78bfa">Violet</option><option value="#34d399">Emerald</option></select></div>
  <div class="mo-ft"><button class="btn bp" style="flex:1" onclick="saveSection()">Save</button><button class="btn bg" onclick="cmo()">Cancel</button></div>
</div></div>

<div class="ovl" id="mo-item"><div class="modal">
  <div class="mo-t" id="mo-item-t">Add Item</div>
  <div class="eg" id="eg-item"></div>
  <div class="fi"><label>Name</label><input id="ii-nm" placeholder="e.g. Vehicle 2 EMI"></div>
  <div class="fi"><label>Monthly Amount (₹)</label><input type="number" id="ii-amt" placeholder="0"></div>
  <div class="mo-ft"><button class="btn bp" style="flex:1" onclick="saveItem()">Add</button><button class="btn bg" onclick="cmo()">Cancel</button></div>
</div></div>

<div class="ovl" id="mo-debt"><div class="modal">
  <div class="mo-t" id="mo-debt-t">Add Debt</div>
  <input type="hidden" id="d-eid">
  <div class="fi"><label>Loan Name</label><input id="d-nm" placeholder="e.g. HDFC Home Loan"></div>
  <div class="g2"><div class="fi"><label>Outstanding (₹)</label><input type="number" id="d-bal" placeholder="500000"></div><div class="fi"><label>Rate (% p.a.)</label><input type="number" id="d-rt" placeholder="9.5" step="0.1"></div></div>
  <div class="g2"><div class="fi"><label>Monthly EMI (₹)</label><input type="number" id="d-emi" placeholder="12000"></div><div class="fi"><label>Type</label><select id="d-tp"><option value="home">🏠 Home Loan</option><option value="vehicle">🚗 Vehicle</option><option value="personal">💰 Personal</option><option value="credit">💳 Credit Card</option><option value="education">📚 Education</option><option value="other">🏦 Other</option></select></div></div>
  <div class="fi"><label>Repayment Type</label><select id="d-rp" onchange="upRepHint()"><option value="emi">📉 Reducing EMI</option><option value="interest">💸 Interest-Only (full principal at closure)</option><option value="bullet">🎯 Bullet/Lump-Sum</option></select></div>
  <div class="fi"><label>Remaining Months (optional)</label><input type="number" id="d-tn" placeholder="36"></div>
  <div class="cb-info xxs" id="rp-hint" style="margin-bottom:.65rem">Standard reducing EMI — principal reduces monthly.</div>
  <div class="mo-ft"><button class="btn bp" style="flex:1" onclick="saveDebt()">Save Debt</button><button class="btn bg" onclick="cmo()">Cancel</button></div>
</div></div>

<div class="ovl" id="mo-sip"><div class="modal">
  <div class="mo-t" id="mo-sip-t">Add SIP</div>
  <input type="hidden" id="sip-eid">
  <div class="fi"><label>Fund Name</label><input id="sip-fn" placeholder="e.g. Mirae Asset Large Cap"></div>
  <div class="g2"><div class="fi"><label>Monthly SIP (₹)</label><input type="number" id="sip-am" placeholder="5000"></div><div class="fi"><label>Category</label><select id="sip-ct"><option value="large">Large Cap</option><option value="index">Index Fund</option><option value="hybrid">Hybrid</option><option value="flexi">Flexi Cap</option><option value="elss">ELSS</option><option value="mid">Mid Cap</option><option value="small">Small Cap</option><option value="debt">Debt Fund</option></select></div></div>
  <div class="g2"><div class="fi"><label>Months Done</label><input type="number" id="sip-do" placeholder="12" min="0"></div><div class="fi"><label>Total Invested (₹)</label><input type="number" id="sip-iv" placeholder="60000"></div></div>
  <div class="g2"><div class="fi"><label>Current Value (₹)</label><input type="number" id="sip-cv" placeholder="65000"></div><div class="fi"><label>Expected Return (% p.a.)</label><input type="number" id="sip-rt" placeholder="12" step="0.5"></div></div>
  <div class="fi"><label>Continue for (months)</label><input type="number" id="sip-pl" placeholder="60" min="1"></div>
  <div class="mo-ft"><button class="btn bp" style="flex:1" onclick="saveSIP()">Save SIP</button><button class="btn bg" onclick="cmo()">Cancel</button></div>
</div></div>

<div class="ovl" id="mo-dcat"><div class="modal">
  <div class="mo-t" id="mo-dcat-t">Daily Expense Category</div>
  <input type="hidden" id="dc-eid">
  <div class="eg" id="eg-dcat"></div>
  <div class="fi"><label>Category Name</label><input id="dc-nm" placeholder="e.g. Morning Tea"></div>
  <div class="fi"><label>Color</label><select id="dc-col">
    <option value="#fb7185">Rose</option><option value="#f59e0b">Amber</option><option value="#2dd4bf">Teal</option><option value="#38bdf8">Sky</option><option value="#a78bfa">Violet</option><option value="#34d399">Emerald</option><option value="#fb923c">Coral</option><option value="#7c73e6">Indigo</option><option value="#e879f9">Fuchsia</option><option value="#4ade80">Green</option>
  </select></div>
  <div class="mo-ft"><button class="btn bp" style="flex:1" onclick="saveDCat()">Save Category</button><button class="btn bg" onclick="cmo()">Cancel</button></div>
</div></div>

<div class="ovl" id="mo-dex"><div class="modal">
  <div class="mo-t" id="mo-dex-t">Edit Daily Expense</div>
  <input type="hidden" id="dex-eid">
  <div class="g2"><div class="fi"><label>Date</label><input type="date" id="de-dt"></div><div class="fi"><label>Category</label><select id="de-cat"></select></div></div>
  <div class="fi"><label>Amount (₹)</label><input type="number" id="de-amt" placeholder="0" min="0"></div>
  <div class="fi"><label>Note (optional)</label><input id="de-note" placeholder="e.g. Lunch at office"></div>
  <div class="mo-ft"><button class="btn bp" style="flex:1" onclick="saveDexEdit()">Save</button><button class="btn bg" onclick="cmo()">Cancel</button></div>
</div></div>

<!-- ── APP ────────────────────────── -->
<header class="hdr">
  <div class="logo">
    <div class="logo-mark">FinanceFreedom</div>
    <div class="logo-sub">// WEALTH OS · v6 · 100% LOCAL</div>
  </div>
  <div class="hdr-r">
    <div class="sav-badge" id="sv-badge"><span class="sav-dot"></span><span id="sv-txt">SAVED</span></div>
    <button class="ico-btn" onclick="toggleTheme()" id="theme-btn" title="Toggle theme">🌙</button>
  </div>
</header>

<nav class="nav">
  <button class="ntab on" onclick="sw('overview',this)">📊 Overview</button>
  <button class="ntab" onclick="sw('expenses',this)">💸 Expenses</button>
  <button class="ntab" onclick="sw('debts',this)">💳 Debts</button>
  <button class="ntab" onclick="sw('sip',this)">📈 SIPs</button>
  <button class="ntab" onclick="sw('invest',this)">💰 Invest</button>
  <button class="ntab" onclick="sw('daily',this)">🗓 Daily</button>
  <button class="ntab" onclick="sw('milestones',this)">🎯 Milestones</button>
  <button class="ntab" onclick="sw('budget',this)">🧮 Budget</button>
  <button class="ntab" onclick="sw('reports',this)">📋 Reports</button>
  <button class="ntab" onclick="sw('statements',this)">🏦 Statements</button>
  <button class="ntab" onclick="sw('ai',this)">🤖 AI</button>
</nav>

<div class="wrap">

<!-- ════ OVERVIEW ════ -->
<div id="pg-overview" class="page on">
  <div class="g4 mb1">
    <div class="kcard"><div class="kl">Monthly Income</div><div class="kv c-ok" id="ov-inc">₹0</div><div class="ks">take-home + extra</div></div>
    <div class="kcard"><div class="kl">Total Expenses</div><div class="kv c-dan" id="ov-exp">₹0</div><div class="ks" id="ov-exps">all categories</div></div>
    <div class="kcard"><div class="kl">Total Debt</div><div class="kv c-rose" id="ov-dbt">₹0</div><div class="ks" id="ov-dbts">0 debts</div></div>
    <div class="kcard"><div class="kl">Monthly Surplus</div><div class="kv" id="ov-sp">₹0</div><div class="ks" id="ov-sps">after costs</div></div>
  </div>
  <div class="g4 mb1">
    <div class="kcard"><div class="kl">SIP Portfolio</div><div class="kv c-sky" id="ov-sipv">₹0</div><div class="ks" id="ov-sips">0 SIPs</div></div>
    <div class="kcard"><div class="kl">Daily Spend (This Month)</div><div class="kv c-rose" id="ov-dex">₹0</div><div class="ks" id="ov-dexs">daily expenses</div></div>
    <div class="kcard"><div class="kl">Interest-Only Loans</div><div class="kv c-dan" id="ov-io">₹0</div><div class="ks">need closure</div></div>
    <div class="kcard"><div class="kl">Debt-Free Date</div><div class="kv c-warn" style="font-size:.95rem;margin-top:.2rem" id="ov-fd">—</div><div class="ks" id="ov-fm">add debts</div></div>
  </div>
  <div class="g2 mb1">
    <div class="card">
      <div class="sh"><div class="shdot"></div>Setup</div>
      <div class="g2"><div class="fi"><label>Monthly Income (₹)</label><input type="number" id="s-inc" placeholder="90000" oninput="sv();rc()"></div><div class="fi"><label>Extra Income/Freelance (₹/mo)</label><input type="number" id="s-xi" placeholder="0" oninput="sv();rc()"></div></div>
      <div class="g2"><div class="fi"><label>Emergency Fund/Savings (₹)</label><input type="number" id="s-sav" placeholder="60000" oninput="sv();rc()"></div><div class="fi"><label>Extra Debt Payment (₹/mo)</label><input type="number" id="s-xp" placeholder="5000" oninput="sv();rc()"></div></div>
      <div class="ib">💡 <strong>Expenses tab</strong> for fixed costs · <strong>Daily tab</strong> for day-to-day · <strong>Debts tab</strong> auto-links EMIs · <strong>Reports tab</strong> for PDF reports</div>
    </div>
    <div class="card">
      <div class="sh"><div class="shdot" style="background:var(--amber)"></div>Debt-Free Countdown</div>
      <div class="rw" style="padding:.4rem 0"><svg width="130" height="130" class="ring"><circle class="rbg" cx="65" cy="65" r="52"/><circle class="rfg" id="r-dbt" cx="65" cy="65" r="52" stroke-dasharray="327" stroke-dashoffset="327" style="stroke:var(--teal)"/></svg><div class="rc"><div style="font-family:var(--fd);font-size:1.55rem;font-weight:900" id="r-pct">0%</div><div class="xxs c-muted">cleared</div></div></div>
      <div style="text-align:center"><div style="font-family:var(--fd);font-size:.92rem;font-weight:900;color:var(--amber)" id="r-date">—</div><div class="xxs c-muted mt05" id="r-mo">Add debts to calculate</div></div>
      <div class="tl mt1" id="ov-tl"></div>
    </div>
  </div>
  <div class="card"><div class="sh"><div class="shdot" style="background:var(--rose)"></div>Expense Snapshot</div><div id="ov-snap"></div></div>
</div>

