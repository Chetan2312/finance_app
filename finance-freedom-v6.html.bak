      <div class="div"></div><div class="kl">Total Projected</div><div style="font-family:var(--fd);font-size:1.5rem;font-weight:900;color:var(--sky)" id="sip-proj">₹0</div><div class="xxs c-muted mt05" id="sip-projd">Add SIPs to see projection</div>
    </div>
