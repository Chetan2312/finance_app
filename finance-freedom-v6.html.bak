    <div class="kcard"><div class="kl">This Week</div><div class="kv c-warn" id="dex-week">₹0</div><div class="ks">7-day total</div></div>
    <div class="kcard"><div class="kl">This Month</div><div class="kv c-rose" id="dex-month">₹0</div><div class="ks" id="dex-month-c">current month</div></div>
    <div class="kcard"><div class="kl">Top Category</div><div class="kv c-sky" id="dex-top" style="font-size:1rem;margin-top:.2rem">—</div><div class="ks" id="dex-tops">this month</div></div>
  </div>

  <!-- Entries list -->
  <div class="card">
    <div class="flex jb ac mb1">
      <div class="sh" style="margin-bottom:0"><div class="shdot"></div>Expense Log</div>
      <div class="flex gap4 ac">
        <select id="dex-filter-mo" class="ainp" style="min-width:0;width:auto" onchange="renderDex()"></select>
        <button class="btn bg bsm" onclick="clearDexFilter()">All</button>
      </div>
    </div>
    <div id="dex-list"><div class="empty"><span class="empty-ic">🗓</span>No daily expenses yet. Use Quick Add above.</div></div>
  </div>
</div>

