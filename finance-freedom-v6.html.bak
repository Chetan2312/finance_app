<div id="pg-reports" class="page">
  <!-- Controls -->
  <div class="report-controls no-print">
    <div class="sh"><div class="shdot" style="background:var(--sky)"></div>Generate Report</div>
    <div class="flex gap6 ac wrap mb1">
      <div class="fi" style="flex:1;min-width:140px;margin-bottom:0"><label>From Date</label><input type="date" id="rpt-from"></div>
      <div class="fi" style="flex:1;min-width:140px;margin-bottom:0"><label>To Date</label><input type="date" id="rpt-to"></div>
      <div class="fi" style="flex:1;min-width:140px;margin-bottom:0"><label>Include</label><select id="rpt-type"><option value="all">All Expenses</option><option value="daily">Daily Only</option><option value="fixed">Fixed Only</option></select></div>
      <div style="padding-top:1.2rem"><button class="btn bp" onclick="genReport()">📊 Generate</button></div>
    </div>
